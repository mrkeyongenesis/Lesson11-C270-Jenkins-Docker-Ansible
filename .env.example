# ============================================================
#  Copy this file to .env and fill in YOUR values:
#      cp .env.example .env
#
#  docker-compose.yml injects these into the Jenkins container,
#  where Configuration as Code (jenkins/casc/jenkins.yaml)
#  imports them as Jenkins credentials and creates the pipeline
#  job automatically. NEVER commit the real .env file!
# ============================================================

# ── Docker Hub ──────────────────────────────────────────────
# Create an access token at: https://hub.docker.com → Account Settings
#   → Security → New Access Token (Read & Write)
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=

# ── GitHub (for Jenkins to clone the repo + webhooks) ───────
# Create a PAT at: https://github.com → Settings → Developer settings
#   → Personal access tokens → Fine-grained token (repo read access)
GITHUB_USER=your-github-username
GITHUB_PAT=
# The repo Jenkins should build (your fork/clone of this project):
GIT_REPO_URL=https://github.com/your-github-username/Lesson11-C270-Jenkins-Docker-Ansible.git

# ── SonarQube (code quality scanning) ───────────────────────
# Start it:  docker compose up -d sonarqube   → http://localhost:9000
# Login admin/admin, then: My Account → Security → Generate Token
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=
SONAR_PROJECT_KEY=student-app

# ── Nexus Repository Manager (private registry) ─────────────
# Start it:  docker compose --profile nexus up -d  → http://localhost:8081
# First-boot password:  docker exec nexus cat /nexus-data/admin.password
NEXUS_USER=admin
NEXUS_PASSWORD=


# ── Jenkins admin login (created automatically by JCasC) ────
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=admin

# ── Grafana admin login (monitoring profile) ────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
