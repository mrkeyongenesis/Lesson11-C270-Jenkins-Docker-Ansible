# Copy to .env and fill in. Used by the helper scripts.
# ============================================================
#  Docker Hub
# ============================================================
DOCKERHUB_USERNAME=keyongenesis

# ============================================================
#  SonarQube (for code quality scanning)
#  Run: docker compose up -d sonarqube
#  Default admin: admin / admin
# ============================================================
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=
SONAR_PROJECT_KEY=student-app

# ============================================================
#  Jenkins (optional — uncomment to pre-configure)
# ============================================================
# JENKINS_ADMIN_USER=admin
# JENKINS_ADMIN_PASSWORD=admin
