[staging]
localhost ansible_connection=local

[production]
localhost ansible_connection=local

# Per-environment published ports (UI = Streamlit, API = FastAPI)
[staging:vars]
ui_port=8501
api_port=8001

[production:vars]
ui_port=8502
api_port=8002

# Variables applied to every target
[all:vars]
ansible_python_interpreter=/usr/bin/python3
